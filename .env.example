# Copie para .env.local e preencha (nunca commite .env.local).
# Supabase — obrigatório para admin, blog dinâmico, formulários que gravam no banco
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# E-mail (formulário de contato via Resend) — opcional em dev
RESEND_API_KEY=
EMAIL_TO=
EMAIL_FROM=

# Google Calendar (agenda no admin) — opcional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# Analytics e SEO (Guia SEO — checklist pré-lançamento)
# GTM: ID do container (ex.: GTM-XXXXXXX) — carrega após consentimento de cookies
NEXT_PUBLIC_GTM_ID=
# Search Console: código da meta tag de verificação (somente o valor, sem aspas)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
